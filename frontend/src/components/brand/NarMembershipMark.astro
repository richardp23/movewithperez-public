---
import { Image } from 'astro:assets';
import narBlack from '../../assets/brand/nar_membershipmark_black.png';
import narWhite from '../../assets/brand/nar_membershipmark_white.png';
import {
  BRAND_MARK_RENDER_SCALE,
  NAR_MEMBERSHIP_MARK_ASPECT,
  NAR_MEMBERSHIP_MARK_HEIGHT,
} from '../../lib/images';

interface Props {
  /** `light` = black mark on light bg; `dark` = white mark on dark bg */
  surface?: 'light' | 'dark';
  height?: number;
}

const { surface = 'light', height = NAR_MEMBERSHIP_MARK_HEIGHT } = Astro.props;
const src = surface === 'light' ? narBlack : narWhite;
const renderHeight = height * BRAND_MARK_RENDER_SCALE;
const width = Math.round(renderHeight * NAR_MEMBERSHIP_MARK_ASPECT);
---
<Image
  src={src}
  alt="REALTOR®"
  width={width}
  height={renderHeight}
  loading="lazy"
  decoding="async"
  class="nar-membership-mark"
  style={`height: ${height}px; width: auto;`}
/>
