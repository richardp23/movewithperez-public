---
import { Image } from 'astro:assets';
import ehoLogo from '../../assets/brand/equal-housing-opportunity.png';
import {
  BRAND_MARK_RENDER_SCALE,
  EHO_MARK_ASPECT,
  EHO_MARK_HEIGHT,
} from '../../lib/images';

interface Props {
  height?: number;
}

const { height = EHO_MARK_HEIGHT } = Astro.props;
const renderHeight = height * BRAND_MARK_RENDER_SCALE;
const width = Math.round(renderHeight * EHO_MARK_ASPECT);
---
<Image
  src={ehoLogo}
  alt="Equal Housing Opportunity"
  width={width}
  height={renderHeight}
  loading="lazy"
  decoding="async"
  class="eho-mark"
  style={`height: ${height}px; width: auto;`}
/>
