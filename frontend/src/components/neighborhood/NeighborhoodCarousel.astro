---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface CarouselItem {
  href: string;
  name: string;
  image: ImageMetadata;
  summary?: string;
}

interface Props {
  items: CarouselItem[];
  /** Accessible name for the carousel region */
  label: string;
  id?: string;
  /** Omit default top margin when the section already provides spacing */
  flushTop?: boolean;
}

const { items, label, id = 'neighborhood-carousel', flushTop = false } = Astro.props;
const headingId = `${id}-heading`;
---
<section
  class:list={['neighborhood-carousel', flushTop && 'neighborhood-carousel--flush']}
  aria-labelledby={headingId}
  data-carousel
>
  <div class="carousel-header">
    <h2 id={headingId} class="carousel-heading">{label}</h2>
    <div class="carousel-controls">
      <button
        type="button"
        class="carousel-btn"
        data-carousel-prev
        aria-label="Show previous neighborhoods"
        aria-controls={`${id}-track`}
      >
        <svg class="carousel-btn-icon" width="20" height="20" viewBox="0 0 20 20" aria-hidden="true" focusable="false">
          <path d="M12 4 6 10 12 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
      <button
        type="button"
        class="carousel-btn"
        data-carousel-next
        aria-label="Show next neighborhoods"
        aria-controls={`${id}-track`}
      >
        <svg class="carousel-btn-icon" width="20" height="20" viewBox="0 0 20 20" aria-hidden="true" focusable="false">
          <path d="M8 4 14 10 8 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
    </div>
  </div>

  <div
    class="carousel-viewport"
    data-carousel-viewport
    tabindex="0"
    role="region"
    aria-roledescription="carousel"
    aria-label={`${label} carousel`}
  >
    <ul class="carousel-track" id={`${id}-track`} data-carousel-track>
      {items.map((item) => (
        <li class="carousel-slide" data-carousel-slide>
          <a href={item.href} class="carousel-card card-interactive">
            <Image
              src={item.image}
              alt=""
              widths={[400, 600, 800]}
              sizes="(max-width: 640px) 85vw, 320px"
              loading="lazy"
              decoding="async"
              class="carousel-card-image card-media-zoom"
            />
            <span class="carousel-card-body">
              <span class="carousel-card-title">{item.name}</span>
              {item.summary && (
                <span class="carousel-card-summary">{item.summary}</span>
              )}
              <span class="carousel-card-cta card-cta btn btn-ghost">Read more</span>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<script>
  import { initCarousels } from '../../lib/carousel.ts';
  initCarousels();
  document.addEventListener('astro:page-load', initCarousels);
</script>
