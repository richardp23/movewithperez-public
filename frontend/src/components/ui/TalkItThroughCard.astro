---
import { SITE } from '../../config';

interface Props {
  title?: string;
  body?: string;
}

const {
  title = 'Prefer to just talk it through?',
  body = "One clear conversation beats ten tabs open. I'll give you a straight answer within one business day.",
} = Astro.props;
---
<div class="card p-6" style="background: var(--color-surface-card);">
  <h3 class="text-xl">{title}</h3>
  <p class="mt-2" style="color: var(--color-mute);">{body}</p>
  <div class="mt-4 flex flex-col gap-2">
    <a href={`tel:${SITE.agentPhone}`} class="btn btn-ghost" style="justify-content: flex-start;">Call {SITE.agentPhone}</a>
    <a href={`mailto:${SITE.email}`} class="btn btn-primary" style="justify-content: flex-start;">Email {SITE.email}</a>
  </div>
  <p class="mt-4 text-sm" style="color: var(--color-mute);">I reply within one business day.</p>
</div>
