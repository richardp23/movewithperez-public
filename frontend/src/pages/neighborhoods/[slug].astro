---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NeighborhoodCarousel from '../../components/neighborhood/NeighborhoodCarousel.astro';
import NeighborhoodMap from '../../components/map/NeighborhoodMap.tsx';
import { withBase } from '../../lib/base-path';
import { toNeighborhoodCarouselItems } from '../../lib/neighborhoods';
import { breadcrumbSchema } from '../../lib/schema';
import { SITE } from '../../config';

export async function getStaticPaths() {
  const items = await getCollection('neighborhoods');
  return items.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);
const guideQuestions = data.questions?.length
  ? data.questions
  : [
      `Which blocks in ${data.name} actually fit my budget right now?`,
      "What's the real commute from here at 8am — door to door?",
      `What do listings in ${data.name} tend to gloss over?`,
      `Would you pick ${data.name} over its neighbors for my situation? Why?`,
    ];

const all = await getCollection('neighborhoods');
const related = all.filter((n) => data.related.includes(n.id)).slice(0, 3);
const relatedCarouselItems = toNeighborhoodCarouselItems(related);

const crumbs = breadcrumbSchema([
  { name: 'Home', url: SITE.domain },
  { name: 'Neighborhoods', url: `${SITE.domain}/neighborhoods` },
  { name: data.name, url: `${SITE.domain}/neighborhoods/${entry.id}` },
]);
---
<BaseLayout
  title={data.seoTitle ?? `${data.name}, NY — Neighborhood Guide`}
  description={data.seoDescription ?? data.summary}
>
  <set:html value={`<script type="application/ld+json">${JSON.stringify(crumbs)}</script>`} />

  <article class="shell py-10">
    <nav class="mb-6 text-sm" aria-label="Breadcrumb" style="color: var(--color-mute);">
      <a href={withBase('/')} style="color: inherit;">Home</a> ›
      <a href={withBase('/neighborhoods')} style="color: inherit;">Neighborhoods</a> ›
      <span>{data.name}</span>
    </nav>

    <Image
      src={data.heroImage}
      alt={data.heroAlt}
      widths={[480, 800, 1200]}
      sizes="(max-width: 800px) 100vw, 800px"
      class="media-frame w-full"
      style="width:100%; height:auto; border-radius: var(--radius-md);"
      loading="eager"
    />
    {data.heroImageCredit && data.heroImageCreditUrl && data.heroImageLicense && data.heroImageLicenseUrl && (
      <figcaption class="mt-2 text-sm" style="color: var(--color-mute);">
        Photo:
        {' '}
        <a href={data.heroImageCreditUrl} target="_blank" rel="noopener noreferrer" style="color: inherit;">
          {data.heroImageCredit}
        </a>
        {' · '}
        <a href={data.heroImageLicenseUrl} target="_blank" rel="noopener noreferrer" style="color: inherit;">
          {data.heroImageLicense}
        </a>
        {' via Wikimedia Commons'}
      </figcaption>
    )}

    <h1 class="title-xl mt-8">{data.name}, NY</h1>
    <p class="mt-3 text-lg" style="color: var(--color-mute);">{data.summary}</p>

    <div class="page-rail mt-8">
      <div class="guide-aside" data-reveal data-reveal-stagger="120">
        <div class="card p-5" style="background: var(--color-surface-card);" data-reveal-item>
          <p class="text-sm font-medium" style="color: var(--color-mute); margin: 0 0 0.6rem;">Neighborhood vibe</p>
          <div class="flex flex-wrap gap-2">
            {data.vibeTags.map((t) => (
              <span class="chip">{t}</span>
            ))}
          </div>
        </div>
        {data.medianPrice && (
          <div class="card p-5" data-reveal-item>
            <p class="text-sm font-medium" style="color: var(--color-mute); margin: 0 0 0.4rem;">Median price</p>
            <p class="text-xl" style="margin: 0; color: var(--color-ink);">Median ~${data.medianPrice.toLocaleString()}</p>
          </div>
        )}
        <div data-reveal-item>
          <NeighborhoodMap
            markers={[{ name: data.name, lat: data.lat, lng: data.lng }]}
            label={`Map of ${data.name}, NY`}
            client:visible
          />
        </div>
        <section class="card p-6 text-center" data-reveal-item>
          <h2 class="text-2xl">Thinking about {data.name}?</h2>
          <p class="mt-2" style="color: var(--color-mute);">{data.ctaLine ?? "I'd love to show you around. No pressure, just local guidance."}</p>
          <a href={withBase('/contact')} class="btn btn-primary mt-5">Book a 15-min call</a>
        </section>
      </div>
      <div class="guide-article">
        <div class="prose max-w-none">
          <Content />
        </div>
      </div>
    </div>

    <section class="card mt-12 p-8 md:p-10" style="background: var(--color-surface-card);">
      <h2 class="text-3xl">Questions to bring me</h2>
      <ul class="mt-5 flex flex-col gap-3 pl-6" style="list-style: disc;">
        {guideQuestions.map((item) => (
          <li style="color: var(--color-body);">{item}</li>
        ))}
      </ul>
    </section>

    {relatedCarouselItems.length > 0 && (
      <div class="mt-14">
        <NeighborhoodCarousel
          id="nearby-neighborhoods"
          label="Nearby neighborhoods"
          items={relatedCarouselItems}
        />
      </div>
    )}
  </article>
</BaseLayout>
