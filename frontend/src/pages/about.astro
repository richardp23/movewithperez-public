---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/base-path';
import { SITE } from '../config';
import agentPortrait from '../assets/photos/agent-portrait.png';
import gradPhoto from '../assets/photos/richard-grad.jpg';

// The "edge" cards: reframe "new agent" as "modern agent".
const edge = [
  {
    title: 'Marketing that looks like this site',
    body: 'I built this site myself, and I build production websites for other businesses too. Most listings get a phone photo and a copy-paste description; yours gets design-led presentation — sharp photography, considered copy, and a web presence made to stop the scroll.',
  },
  {
    title: 'You always know what\u2019s happening',
    body: 'No black box. I answer my phone, I follow up the same day, and you\u2019ll never wonder where things stand. With me, you\u2019re the whole client list — not a row in someone\u2019s database.',
  },
  {
    title: 'Local knowledge, written down',
    body: 'I publish real neighborhood guides — schools, commutes, prices, the honest trade-offs. If I\u2019m willing to put it in writing for everyone, imagine the detail you get one-on-one.',
  },
];
---
<BaseLayout
  title={`About ${SITE.agentName} — ${SITE.brokerage}`}
  description={`${SITE.agentName} is a ${SITE.jobTitle} with ${SITE.brokerage}, bringing a modern, design-led, education-first approach to residential real estate in New York.`}
>
  <!-- Hero: portrait + story intro -->
  <section class="shell py-16">
    <div class="grid items-center gap-10 md:grid-cols-2">
      <Image
        src={agentPortrait}
        alt={`${SITE.agentName}, ${SITE.jobTitle} at ${SITE.brokerage}`}
        widths={[480, 768, 1024]}
        sizes="(max-width: 768px) 100vw, 50vw"
        class="media-frame card-lg w-full"
        style="border: 1px solid var(--color-hairline); object-fit: cover; aspect-ratio: 4/3;"
        loading="eager"
      />
      <div>
        <p class="eyebrow">About me</p>
        <h1 class="title-xl mt-2" style="line-height: 1.15;">
          A fresh take on an industry that hasn't changed in decades
        </h1>
        <p class="mt-5 text-lg" style="color: var(--color-mute);">
          I'm {SITE.agentName}, a {SITE.jobTitle.toLowerCase()} with {SITE.brokerage}, born and
          raised in Richmond Hill. I work across southern Queens — Woodhaven, Glendale, Howard
          Beach, Ozone Park, and the neighborhoods in between — because this is home, not just a
          market on a map.
        </p>
      </div>
    </div>
  </section>

  <!-- Story -->
  <section class="mx-auto max-w-3xl px-5 pb-16">
    <h2 class="text-3xl">Why I do this work</h2>
    <div class="mt-5 flex flex-col gap-4 text-lg" style="color: var(--color-body);">
      <p>
        I'm a Queens kid — lived in Richmond Hill my whole life, attended schools like PS 66 and The
        Scholars' Academy High School, and then went to St. John's University, where I graduated in May
        2026 with a B.S. in Computer Science. Now I'm back for my master's, expected to graduate in May
        2027 with a M.S. in Artificial Intelligence and Data Science.
      </p> 
      <p>
        Southern Queens isn't a market I picked up; it's the place I know block by block,
        and I'm proud to call it home. I got licensed because I kept watching neighbors take on one of the
        biggest decisions of their lives without anyone in their corner who actually lived here.
      </p>
      <p>
        I also teach. I've spent summers with All Star Code helping high schoolers learn to code — I
        started as a teaching fellow and came back to lead, the youngest lead instructor the program
        had ever had, at 18, and I'm leading again this summer. That's shaped how I do this work more
        than the license has: I'd rather you understand a decision than just take my word for it.
      </p>
      <p>
        Because a move is almost never just a move. People are leaving the nest, settling things
        after a loss, relocating for a job, or finally chasing a change of pace — and the paperwork
        is the smallest thing on their mind. My job is to carry the whole process so you can handle
        the part that actually matters, and to teach you enough along the way that you always know
        what's happening and why.
      </p>
      <p>
        I'm newer to the license than the agents on the bus-stop benches, and that's the point — no
        autopilot, no twenty-year-old playbook, just my full attention. So here's the promise: I'll
        do the heavy lifting, and I'll tell you the truth even when it's not what sells fastest. If a
        house is wrong for you, I'll say so. If your asking price is a dream, I'll show you the comps.
        You'll always know I'm on your side of the table.
      </p>
    </div>
  </section>

  <!-- The edge -->
  <section class="shell pb-16">
    <h2 class="text-3xl">What working with me looks like</h2>
    <div class="mt-6 grid gap-2 md:grid-cols-3" data-reveal data-reveal-stagger="120">
      {edge.map((e) => (
        <div class="card p-8" data-reveal-item>
          <h3 class="text-xl" style="margin: 0;">{e.title}</h3>
          <p class="mt-3" style="color: var(--color-mute); margin-bottom: 0;">{e.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- A little about me (personal) -->
  <section class="shell pb-16">
    <div class="grid items-center gap-10 md:grid-cols-2">
      <div>
        <p class="eyebrow">Off the clock</p>
        <h2 class="text-3xl mt-2">A little about me</h2>
        <div class="mt-5 flex flex-col gap-4 text-lg" style="color: var(--color-body);">
          <p>
            Real estate is personal, so here's the person behind it. I still live in the
            neighborhood I sell in — occassionally you can catch me grabbing a slice at Tom's
            by the 104th Street J Train stop.
          </p>
          <p>
            Being a Queens kid comes with allegiances. I've been a Mets fan my whole life — for
            better and, honestly, for worse — and these days you'll find me watching the Bills on
            Sundays and the Knicks whenever they're on. The St. John's Red Storm, too; that one
            comes with the diploma.
          </p>
          <p>
            The only thing I can't commit to is a hockey team. I've been to Islanders games and had a
            blast, but Madison Square Garden has my heart — it's home to both the Knicks and the Red
            Storm — so the Rangers keep pulling me back. Fitting, maybe, for a guy whose whole pitch
            is <em>do your homework before you commit</em>.
          </p>
        </div>
      </div>
      <Image
        src={gradPhoto}
        alt={`${SITE.agentName} at his St. John's University graduation`}
        widths={[480, 768, 1024]}
        sizes="(max-width: 768px) 100vw, 50vw"
        class="media-frame card-lg w-full"
        style="border: 1px solid var(--color-hairline); object-fit: cover; aspect-ratio: 3/4;"
        loading="lazy"
      />
    </div>
  </section>

  <!-- Credentials -->
  <section class="shell pb-16">
    <div class="card p-8" style="background: var(--color-surface-card);">
      <h2 class="text-2xl">Credentials & coverage</h2>
      <dl class="mt-5 grid gap-6 sm:grid-cols-3">
        <div>
          <dt class="text-sm font-medium" style="color: var(--color-mute);">License</dt>
          <dd class="mt-1" style="margin-left: 0;">{SITE.licenseDisclosure}</dd>
        </div>
        <div>
          <dt class="text-sm font-medium" style="color: var(--color-mute);">Brokerage</dt>
          <dd class="mt-1" style="margin-left: 0;">
            <a href={SITE.brokerWebsite} target="_blank" rel="noopener noreferrer" style="color: var(--color-ink);">
              {SITE.brokerage}
            </a>
          </dd>
        </div>
        <div>
          <dt class="text-sm font-medium" style="color: var(--color-mute);">Areas served</dt>
          <dd class="mt-1" style="margin-left: 0;">{SITE.areaServed.join(' · ')}</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-3xl px-5 pb-20 text-center">
    <h2 class="text-3xl">Let's see if we're a fit</h2>
    <p class="mx-auto mt-3 max-w-xl text-lg" style="color: var(--color-mute);">
      A 15-minute call, zero pressure. Tell me what you're hoping for and I'll tell you honestly
      how I can help — or point you to someone who can.
    </p>
    <a href={withBase('/contact')} class="btn btn-primary mt-6">Get in touch</a>
  </section>
</BaseLayout>
