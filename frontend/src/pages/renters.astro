---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/base-path';
import { faqSchema } from '../lib/schema';
import { SITE } from '../config';
import TalkItThroughCard from '../components/ui/TalkItThroughCard.astro';
import QuestionsBlock from '../components/ui/QuestionsBlock.astro';

const steps = [
  {
    title: 'Share your target',
    body: 'A quick call to set your move date, budget range, must-haves, and dealbreakers so we focus on rentals that actually fit.',
  },
  {
    title: 'Tour the right options',
    body: 'We prioritize listings that match your commute and daily routine, not just what photographs well online.',
  },
  {
    title: 'Screen the real costs',
    body: 'Before you apply, we confirm monthly rent plus likely utilities, parking, and any disclosed fees so there are no surprises.',
  },
  {
    title: 'Apply cleanly',
    body: "I help you package income docs, credit details, references, and guarantor paperwork so landlords can approve you faster.",
  },
  {
    title: 'Review and sign',
    body: 'We check lease terms, deposits, and move-in timing before you commit so you know exactly what you are agreeing to.',
  },
];

const faqs = [
  {
    q: 'Do I have to pay a broker fee?',
    a: "Usually not. Under the FARE Act, if the landlord hired the listing broker, the landlord pays. You only pay a fee if you hire me directly as your renter's agent, agreed up front.",
  },
  {
    q: 'How much income do I need?',
    a: 'Landlords commonly want about 40x the monthly rent, or a guarantor (often ~80x) if you are under.',
  },
  {
    q: 'How big a deposit?',
    a: "One month's rent maximum, under NY law.",
  },
  {
    q: 'Can I rent with a guarantor or thin credit?',
    a: "Often yes - let's talk through your situation.",
  },
  {
    q: 'How fast can I move?',
    a: "Depends on the building's approval; co-op and condo rentals take longer because of board review.",
  },
];

const faqLd = faqSchema(faqs);
---
<BaseLayout
  title="Renting in Southern Queens - Clear, Honest Guidance"
  description="Straight answers on broker fees, application expectations, and rental strategy across southern Queens."
>
  <set:html value={`<script type="application/ld+json">${JSON.stringify(faqLd)}</script>`} />

  <!-- Hero -->
  <section class="mx-auto max-w-3xl px-5 pt-16 pb-12">
    <p class="eyebrow">For renters</p>
    <h1 class="title-xl mt-2" style="line-height: 1.15;">
      Renting in southern Queens, done straight
    </h1>
    <p class="mt-5 text-lg" style="color: var(--color-mute);">
      New to the area or just moving across the neighborhood - renting here should be clear about
      what you'll pay, what you'll need, and who's actually working for you. Here's how I keep it
      that way.
    </p>
    <div class="mt-7 flex flex-wrap gap-3">
      <a href={withBase('/contact')} class="btn btn-primary">Talk about your rental search</a>
      <a href={withBase('/neighborhoods')} class="btn btn-ghost">Browse neighborhood guides</a>
    </div>
  </section>

  <!-- Process -->
  <section class="shell pb-16" aria-labelledby="process-heading">
    <h2 id="process-heading" class="text-3xl">The process, step by step</h2>
    <div class="mt-6 grid gap-8 xl:grid-cols-[minmax(0,1fr)_20rem] xl:items-start">
      <ol class="timeline" data-reveal data-reveal-stagger="160">
        {steps.map((s, i) => (
          <li class="card flex gap-5 p-6" data-reveal-item>
            <span aria-hidden="true" class="step-number">{i + 1}</span>
            <div>
              <h3 class="text-xl" style="margin: 0;">{s.title}</h3>
              <p class="mt-2" style="color: var(--color-mute); margin-bottom: 0;">{s.body}</p>
            </div>
          </li>
        ))}
      </ol>
      <div class="xl:sticky xl:top-24">
        <TalkItThroughCard />
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-5 pb-16" aria-labelledby="broker-fee-heading">
    <h2 id="broker-fee-heading" class="text-3xl">The broker fee, in plain English</h2>
    <p class="mt-4" style="color: var(--color-mute);">
      New York changed the rules in 2025. Under the FARE Act, whoever hires the broker pays the
      broker. If a landlord I represent has a place listed, you don't owe me a fee - landlord-hired
      listing brokers can't charge tenants anymore, and every listing must spell out any fees you'd
      pay before you sign. The only time you'd pay me is if you hire me as your own renter's agent
      to find and negotiate options for you - and if we do that, we agree on it, in writing, up
      front. No surprises at signing.
    </p>
  </section>

  <section class="mx-auto max-w-3xl px-5 pb-16" aria-labelledby="apply-heading">
    <h2 id="apply-heading" class="text-3xl">What you'll need to apply</h2>
    <p class="mt-4" style="color: var(--color-mute);">
      Most southern-Queens landlords ask for the same things: photo ID, proof of income (commonly
      around 40x the monthly rent, or a guarantor if you're under that), a credit check, and
      references. Two are NY law, not negotiable: a landlord's application/background-check fee is
      capped at $20, and the security deposit can't exceed one month's rent. If anyone asks for
      more, ask me.
    </p>
  </section>

  <section class="mx-auto max-w-3xl px-5 pb-16" aria-labelledby="look-heading">
    <h2 id="look-heading" class="text-3xl">Where to look</h2>
    <p class="mt-4" style="color: var(--color-mute);">
      Rentals here aren't one thing - upstairs units in two-family homes, apartments in co-op and
      condo buildings, and larger rental buildings closer to the avenues. Each neighborhood rents
      differently; start with my <a href={withBase('/neighborhoods')}>all five neighborhood guides</a>.
    </p>
  </section>

  <section class="mx-auto max-w-3xl px-5 pb-16" aria-labelledby="role-heading">
    <h2 id="role-heading" class="text-3xl">What I do for renters</h2>
    <ul class="mt-5 flex flex-col gap-3 pl-6" style="list-style: disc;">
      {[
        "Tell you the real monthly cost - rent plus what utilities and parking actually run on that block.",
        "Flag what photos hide: the bus that isn't as express as it looks, the unit over a busy storefront.",
        'Help you put together an application landlords take seriously the first time.',
        "Be straight about whether a place is worth it - even when that means telling you to keep looking.",
      ].map((item) => (
        <li style="color: var(--color-body);">{item}</li>
      ))}
    </ul>
  </section>

  <!-- FAQ -->
  <section class="shell pb-16" aria-labelledby="faq-heading">
    <h2 id="faq-heading" class="text-3xl">Common questions</h2>
    <div class="faq-grid mt-5" data-reveal data-reveal-stagger="180">
      {faqs.map((f) => (
        <details class="card p-6" data-reveal-item>
          <summary class="text-lg" style="cursor: pointer; font-weight: 500; color: var(--color-ink);">{f.q}</summary>
          <p class="mt-3" style="color: var(--color-mute); margin-bottom: 0;">{f.a}</p>
        </details>
      ))}
    </div>
  </section>

  <QuestionsBlock
    questions={[
      'Is this block as quiet and convenient as it looks?',
      "What's the real commute from here at 8am?",
      "Is the landlord responsive, and what's the building's reputation?",
      'Should I look one neighborhood over for more space at this price?',
    ]}
  />

  <!-- CTA -->
  <section class="mx-auto max-w-3xl px-5 pb-20 text-center">
    <div class="card-lg card p-10">
      <h2 class="text-3xl">Looking to rent?</h2>
      <p class="mx-auto mt-3 max-w-xl text-lg" style="color: var(--color-mute);">
        Text or email me and I'll help you sort options quickly, clearly, and without pressure.
      </p>
      <a href={withBase('/contact')} class="btn btn-primary mt-6">Start your rental search</a>
      <p class="mt-4 text-sm" style="color: var(--color-mute);">
        Or just email {SITE.email} - I reply within one business day.
      </p>
    </div>
  </section>
</BaseLayout>
