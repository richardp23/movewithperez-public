---
import BaseLayout from '../layouts/BaseLayout.astro';
import ValuationForm from '../components/forms/ValuationForm.tsx';
import { withBase } from '../lib/base-path';
import { faqSchema } from '../lib/schema';
import { SITE } from '../config';
import TalkItThroughCard from '../components/ui/TalkItThroughCard.astro';
import QuestionsBlock from '../components/ui/QuestionsBlock.astro';

const faqs = [
  { q: 'What does it cost to sell?', a: 'Commission and any prep costs are discussed up front, with no surprises. We tailor the plan to your home and goals.' },
  { q: 'How long will it take?', a: 'Timeline depends on your home and the market. After a quick consult, I can give you a realistic range.' },
  { q: 'Do I need to renovate first?', a: 'Not necessarily. We focus on the highest-return prep and skip the rest.' },
  {
    q: 'How will you actually market my home?',
    a: "Design-led presentation — photography I direct, considered copy, a web standard you can judge by this site — plus full MLS exposure through EXIT Realty Central so every buyer's agent and portal sees it. You'll approve the listing before it goes live.",
  },
  {
    q: "Do I have to offer the buyer's agent a commission?",
    a: "No — it's negotiable, and since the 2024 settlement that's explicit. There are real trade-offs either way, and we'll talk through them honestly before we list. Whatever we decide goes in writing.",
  },
  {
    q: "What if I'm not ready to sell yet?",
    a: 'Then don\'t. A valuation now just gives you a baseline and a plan — what to do (and skip) before listing, and what timing looks like in this market. No pressure, no follow-up campaign.',
  },
];
const faqLd = faqSchema(faqs);
const processSteps = [
  {
    title: 'Pricing consult',
    body: "We walk the home together and I pull real comps — what actually closed nearby, not what's sitting on the market hoping. You'll see how I get to a number, line by line.",
  },
  {
    title: 'Prep, without over-spending',
    body: "What to fix, what to clean, and what to leave alone. Some projects return their cost in this market; many don't. I'll tell you which is which, and coordinate vendors if you need them.",
  },
  {
    title: 'Launch with real marketing',
    body: "Professional photography I direct personally, listing copy written for your specific block, and full MLS exposure through EXIT Realty Central. The first two weeks set the tone — we make them count.",
  },
  {
    title: 'Offers & negotiation',
    body: "Every offer comes to you with a plain-English breakdown: your estimated net, the buyer's financing strength, and the timeline risk. You decide; I negotiate.",
  },
  {
    title: 'Contract to close',
    body: 'Attorney review, inspection negotiation, appraisal, buyer financing milestones, walkthrough, keys. NY closings have a lot of moving parts — I track every one so nothing slips.',
  },
];
const pricing = [
  {
    term: 'Comps vs. online estimates',
    def: "Online estimates run formulas on public records. They can't see your renovated kitchen — or the el two blocks away. I price from closed sales on comparable blocks, and I show you the comps, not just a number.",
  },
  {
    term: 'The first two weeks',
    def: "A new listing gets its most attention right after launch. Pricing high 'to leave room' and cutting later usually nets less than pricing right at debut. The debut is the strategy.",
  },
  {
    term: 'Commission, in plain terms',
    def: "Commission is negotiable and always has been — the 2024 industry settlement made that explicit. We'll agree on everything in writing before the sign goes up, including whether and what to offer a buyer's agent.",
  },
  {
    term: 'Your net, not the price',
    def: 'What matters is what you walk away with: price minus payoff, transfer taxes, attorney fee, and commission. I prepare a line-by-line net sheet before you list — and update it with every offer.',
  },
];
---
<BaseLayout
  title="What's Your Home Worth? — Free Home Valuation"
  description="Get a free, no-obligation home valuation and a modern, calm selling process."
>
  <set:html value={`<script type="application/ld+json">${JSON.stringify(faqLd)}</script>`} />

  <section class="mx-auto max-w-3xl px-5 py-12">
    <h1 class="title-xl">What's your home worth?</h1>
    <p class="mt-3 text-lg" style="color: var(--color-mute);">
      Free, no-obligation, and zero pressure. I'll review your home and follow up within one business day.
    </p>

    <div class="mt-8" data-reveal>
      <ValuationForm client:visible />
    </div>

    <h2 class="mt-14 text-2xl">Why list with me</h2>
    <p class="mt-2" style="color: var(--color-mute);">
      A modern, design-led marketing approach, fast and responsive communication, and full attention on
      your sale — not a number on a leaderboard.
    </p>
    <p class="mt-2" style="color: var(--color-mute);">
      Most listings get a phone photo, a copy-paste description, and a prayer. Yours gets the presentation standard you can see on this site — and an agent who tells you the truth about price, because a listing that sits costs you more than an honest conversation up front.
    </p>
  </section>

  <section class="shell pb-16" aria-labelledby="process-heading">
    <h2 id="process-heading" class="text-3xl">The process, step by step</h2>
    <div class="mt-6 grid gap-8 xl:grid-cols-[minmax(0,1fr)_20rem] xl:items-start">
      <ol class="timeline" data-reveal data-reveal-stagger="170">
        {processSteps.map((step, i) => (
          <li class="card flex gap-5 p-6" data-reveal-item>
            <span aria-hidden="true" class="step-number">{i + 1}</span>
            <div>
              <h3 class="text-xl" style="margin: 0;">{step.title}</h3>
              <p class="mt-2" style="color: var(--color-mute); margin-bottom: 0;">{step.body}</p>
            </div>
          </li>
        ))}
      </ol>
      <div class="xl:sticky xl:top-24">
        <TalkItThroughCard />
      </div>
    </div>
  </section>

  <section class="shell pb-16" aria-labelledby="pricing-heading">
    <div class="card p-8 md:p-10" style="background: var(--color-surface-card);">
      <h2 id="pricing-heading" class="text-3xl">Pricing, in plain English</h2>
      <p class="mt-3 max-w-2xl" style="color: var(--color-mute);">
        You don't need a real-estate course — just the four ideas that actually move your bottom line.
      </p>
      <dl class="mt-7 grid gap-2 md:grid-cols-2 2xl:grid-cols-4" data-reveal data-reveal-stagger="140">
        {pricing.map((f) => (
          <div class="card p-6" data-reveal-item>
            <dt class="text-lg" style="font-weight: 600; color: var(--color-ink);">{f.term}</dt>
            <dd class="mt-2" style="color: var(--color-mute); margin-left: 0;">{f.def}</dd>
          </div>
        ))}
      </dl>
      <!-- BROKER REVIEW -->
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-5 pb-16" aria-labelledby="role-heading">
    <h2 id="role-heading" class="text-3xl">What I actually do for you</h2>
    <ul class="mt-5 flex flex-col gap-3 pl-6" style="list-style: disc;">
      {[
        "Direct the photography and write copy that sells your block, not cliches",
        'Build the pricing brief from closed comps — and show you the work',
        'Give you a weekly rundown: showings, feedback, and what it means',
        'Present every offer with a net sheet, not just a headline number',
        'Negotiate price, repairs, and timing on your behalf',
        'Coordinate attorney, inspection, appraisal, and title so deadlines do not slip',
      ].map((item) => (
        <li style="color: var(--color-body);">{item}</li>
      ))}
    </ul>
  </section>

  <section class="shell pb-16" aria-labelledby="faq-heading">
    <h2 id="faq-heading" class="text-3xl">Common questions</h2>
    <div class="faq-grid mt-5" data-reveal data-reveal-stagger="190">
      {faqs.map((f) => (
        <details class="card p-5" data-reveal-item>
          <summary style="cursor: pointer; font-weight: 500;">{f.q}</summary>
          <p class="mt-2" style="color: var(--color-mute); margin-top: 0.5rem;">{f.a}</p>
        </details>
      ))}
    </div>
    <!-- BROKER REVIEW -->
  </section>

  <QuestionsBlock
    questions={[
      'What did homes like mine actually close for — not list for?',
      'What would you fix before listing, and what would you skip?',
      'How would you market this specific house?',
      "What's my realistic net at the price you're recommending?",
    ]}
  />

  <section class="mx-auto max-w-3xl px-5 pb-20 text-center">
    <div class="card-lg card p-10">
      <h2 class="text-3xl">Ready when you are</h2>
      <p class="mx-auto mt-3 max-w-xl text-lg" style="color: var(--color-mute);">
        Start with a free, no-pressure consult. If you're not ready yet, you still leave with a clearer plan.
      </p>
      <a href={withBase('/contact')} class="btn btn-primary mt-6">Book a seller consult</a>
      <p class="mt-4 text-sm" style="color: var(--color-mute);">
        Or just email {SITE.email} — I reply within one business day.
      </p>
    </div>
  </section>
</BaseLayout>
