# Monorepo environment template (reference only).
# Use app-specific templates:
# - frontend/.env.example
# - worker/.dev.vars.example

# Frontend (public, build-time)
PUBLIC_FORM_ENDPOINT="https://<worker-name>.<account>.workers.dev"
PUBLIC_TURNSTILE_SITEKEY="0x4AAAA..."

# Worker (local dev with `wrangler dev` typically uses worker/.dev.vars)
RESEND_API_KEY=re_REDACTED
TURNSTILE_SECRET_KEY=REDACTED
TO_EMAIL="you@example.com"
FROM_EMAIL="Your Name <forms@yourdomain.com>"
ALLOWED_ORIGIN="https://your-site.example"
CRM_WEBHOOK_URL=""
RATE_LIMIT_MAX_PER_MINUTE="20"
